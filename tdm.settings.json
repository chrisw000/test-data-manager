{
  // Demo settings: runs the example features against both sample domains on SQLite.
  // Plugin folders point at the sample domains' build output — in production these are
  // populated by NuGet restore of the domain data packages (handoff §3).
  "run": {
    "name": "sample-domains-demo",
    "failurePolicy": "BestEffort",
    "lifecycle": "Persistent",
    "defaultSeed": 1,
    "featurePaths": ["features/**/*.feature"],
    "benchmark": true,
    "outputPath": "./output"
  },
  "domains": [
    {
      "name": "Orders",
      "package": "Acme.Orders.Data.Persistence",
      "pluginPath": "tests/Acme.Orders.Data.Persistence/bin/Debug/net10.0",
      "provider": "Sqlite",
      "connectionString": "Data Source=./output/orders-demo.db",
      "conventionProfile": "modern",
      "persistence": "RepositoryFirst",
      "ensureCreated": true,
      // W4-D5: Bogus vocabulary for generated names/addresses; determinism unchanged.
      "locale": "en_GB"
    },
    {
      "name": "Billing",
      "package": "Acme.Billing.Data.Infrastructure",
      "pluginPath": "tests/Acme.Billing.Data.Infrastructure/bin/Debug/net10.0",
      "provider": "Sqlite",
      "connectionString": "Data Source=./output/billing-demo.db",
      "conventionProfile": "legacy",
      "persistence": "DbContextOnly",
      "externalReferences": "Synthesize",
      "ensureCreated": true
    }
  ],
  "entities": {
    // Product has no write repository by design — explicit policy exemption (docs/adr-0001).
    "Product": { "naturalKey": "Sku", "requireRepository": false },
    "Order": {
      "naturalKey": "OrderNumber",
      // W4-D4: declarative statistical generation — applied over the faker's output,
      // drawn from the per-scenario seed; step overrides still win.
      "properties": {
        "Status": { "weights": { "Pending": 0.6, "Shipped": 0.3, "Cancelled": 0.1 } },
        "Total": { "distribution": "lognormal", "mean": 120, "sigma": 1.2 }
      }
    },
    "Invoice": { "naturalKey": "InvoiceNumber" },
    "Customer": { "externalBehavior": "Projection", "projectionEntity": "CustomerSummary" },
    "CustomerSummary": { "naturalKey": "Name" }
  }
}
